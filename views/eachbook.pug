doctype html
html
  head
    title Thrift Books
    style
      include ../static/styleeachbook.css
  body
    //- header
    div.container
        div.navbar
            div#logo
                img(src="/static/img/logo.jpg", alt="")
                a(href="/") Thrift Books

            nav#navbar
                ul  
                    li #[a(href="/books") Books] 
                    li #[a(href="/myStore") My Store]
            

        div#search
            form(id="searchbar" action="/booksearched" method="GET")
                input(type="text" id="booksrchd" placeholder="Search Book" value="" name="booksearched")
                //- input(type="button" value="Submit" onclick="mysearch();")
                Button(type="submit") &#128269;
                    
                


    div#eachbookpg 
        div#container-1
            div#row 
                div#img-col 
                    img(src=`${bookinfo.bimg}`, alt="")
                
                div#info-col 
                    div#info-bg
                        div#info-btn
                            p Book : #{bookinfo.book}
                            br
                            p Author : #{bookinfo.author}
                            br
                            p Condition : #{bookinfo.condition}
                            br
                            p Price : Rs. #{bookinfo.price}
                            br
                            a(href="/") Add to Cart
       
        div#container-2
            div.row-rec
                    each book in books
                        div.col-rec
                            a(id=book.id onclick='myJavaScriptFunction(id);')
                                img(src=`${book.bimg}`)
                                p #{book.book}
                                p Rs. #{book.price}

    footer#footer
        div#container-f
            div#row1-f 
                div#col1-f 
                    h2 About Us 
                    p Want to read more and more books but find it expensive? Well, we're here for your rescue! Thrift Books and feed the bookworm in you. You can also sell your used books here and help other readers like you. Thrifting books is good for you and the environment and that's all we want. Happy Books to you.

                div#col2-f 
                    h3 Follow Us 
                    h4 Instagram 
                    h4 Twitter
                    h4 Facebook 
                
                div#col3-f 
                    h3 Contact Us 
                    h4 Thrift-Books.com 
                    h4 #1218,
                    h4 Sector-15, Chandigarh,
                    h4 Punjab -131001
                    h4 P:+91-9050111218
                    h4 E-mail:contact@gmail.com

            div#row2-f 
                div#cprt
                    |   Copyright Ⓒ Thrift-Books.com | All rights reserved
    
    script. 

        function myJavaScriptFunction(bookid){
            console.log(bookid);
            var booklink = document.getElementById(bookid);
            booklink.href = "/eachbook?id="+ bookid;
            console.log(booklink.href);
        }                                     

